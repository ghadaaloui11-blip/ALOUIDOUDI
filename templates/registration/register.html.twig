{% extends 'base.html.twig' %}

{% block title %}Inscription - Bibliothèque{% endblock %}

{% block body %}
<div class="auth-layout">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-logo"><i class="fas fa-user-plus"></i> Biblio<span>thèque</span></div>
            <div class="auth-sub">Créez votre compte en quelques instants</div>
        </div>
        
        <div class="auth-body">
            {{ form_start(registrationForm) }}
                <div class="form-group">
                    {{ form_label(registrationForm.email, 'Adresse Email', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control', 'placeholder': 'votre@email.com'}}) }}
                    <div class="form-error">{{ form_errors(registrationForm.email) }}</div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="form-group">
                        {{ form_label(registrationForm.nom, 'Nom', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(registrationForm.nom, {'attr': {'class': 'form-control', 'placeholder': 'Nom'}}) }}
                    </div>
                    <div class="form-group">
                        {{ form_label(registrationForm.prenom, 'Prénom', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(registrationForm.prenom, {'attr': {'class': 'form-control', 'placeholder': 'Prénom'}}) }}
                    </div>
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.roles, 'Je suis...', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(registrationForm.roles, {'attr': {'class': 'form-select'}}) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.identifier, 'CIN / Matricule', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(registrationForm.identifier, {'attr': {'class': 'form-control', 'placeholder': 'Ex: 12345678'}}) }}
                    <small style="color: var(--muted); font-size: 0.7rem;">{{ registrationForm.identifier.vars.help }}</small>
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.plainPassword, 'Mot de passe', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control', 'placeholder': '••••••••'}}) }}
                    <div class="form-error">{{ form_errors(registrationForm.plainPassword) }}</div>
                </div>

                <div class="form-group" style="display: flex; align-items: center; gap: 0.5rem; margin-top: 1rem;">
                    {{ form_widget(registrationForm.agreeTerms) }}
                    <label for="{{ registrationForm.agreeTerms.vars.id }}" style="font-size: 0.75rem; color: var(--muted);">
                        J'accepte les conditions d'utilisation
                    </label>
                </div>

                <div style="margin-top: 1.5rem;">
                    <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">
                        <i class="fas fa-check"></i> S'inscrire
                    </button>
                </div>
            {{ form_end(registrationForm) }}
        </div>
        
        <div class="auth-footer">
            Déjà un compte ? <a href="{{ path('app_login') }}">Connectez-vous ici</a>
        </div>
    </div>
</div>
{% endblock %}
