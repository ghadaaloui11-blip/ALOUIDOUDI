{% extends 'base.html.twig' %}

{% block title %}Tableau de Bord - Bibliothécaire{% endblock %}

{% block breadcrumb %}
    <li class="sep">/</li>
    <li>Mon espace</li>
    <li class="sep">/</li>
    <li>Tableau de bord</li>
{% endblock %}

{% block body %}
    <div class="page-header">
        <h1 class="page-title">
            <em>Bienvenue, {{ bibliothecaire.prenom }}</em>
            Tableau de Bord 🌸
        </h1>
    </div>

    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-label">Mes Emprunts Gérés</div>
            <div class="stat-value">{{ emprunts|length }}</div>
            <div class="stat-delta"><i class="fas fa-book"></i> Livres en circulation</div>
        </div>
        <div class="stat-card" style="border-top-color: var(--pink-500)">
            <div class="stat-label">Profil</div>
            <div class="stat-value" style="font-size: 1.2rem; margin-top: 0.5rem;">Matricule: {{ bibliothecaire.matricule }}</div>
            <div class="stat-delta">{{ bibliothecaire.nom }} {{ bibliothecaire.prenom }}</div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h3 style="margin-bottom: 1.5rem; font-family: 'Playfair Display', serif; color: var(--pink-600);">Liste des emprunts récents</h3>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Date Emprunt</th>
                        <th>Adhérent</th>
                        <th>État</th>
                        <th>Pénalité</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for emprunt in emprunts %}
                    <tr>
                        <td>{{ emprunt.dateEmprunt ? emprunt.dateEmprunt|date('d/m/Y') : '' }}</td>
                        <td>{{ emprunt.adherent.nom }} {{ emprunt.adherent.prenom }}</td>
                        <td>
                            <span class="badge badge-{{ emprunt.etat|replace({'_': '-'}) }}">
                                {{ emprunt.etat|capitalize|replace({'_': ' '}) }}
                            </span>
                        </td>
                        <td>{{ emprunt.penalite ? emprunt.penalite ~ ' €' : '0 €' }}</td>
                        <td class="action-group">
                            <a href="{{ path('app_emprunt_show', {'id': emprunt.id}) }}" class="action-link view">
                                <i class="fas fa-eye"></i> Voir
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr class="empty-row">
                        <td colspan="5">
                            <i class="fas fa-folder-open"></i>
                            Aucun emprunt trouvé.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
