{% extends 'base.html.twig' %}

{% block title %}Profil Manquant{% endblock %}

{% block body %}
<div style="max-width: 600px; margin: 4rem auto; text-align: center;">
    <div class="card">
        <div class="card-body" style="padding: 3rem;">
            <i class="fas fa-user-circle" style="font-size: 4rem; color: var(--pink-300); margin-bottom: 1.5rem;"></i>
            <h2 style="font-family: 'Playfair Display', serif; color: var(--ink); margin-bottom: 1rem;">Oups ! Profil {{ role }} manquant</h2>
            <p style="color: var(--muted); margin-bottom: 2rem;">
                Il semble que votre compte n'ait pas de profil <strong>{{ role }}</strong> associé. 
                Cela arrive généralement si votre compte a été créé manuellement ou sans les informations de profil.
            </p>
            
            <div style="display: flex; flex-direction: column; gap: 1rem;">
                <a href="{{ path('app_logout') }}" class="btn btn-primary" style="justify-content: center;">
                    <i class="fas fa-sign-out-alt"></i> Se déconnecter et se réinscrire
                </a>
                <a href="{{ path('app_home') }}" class="btn btn-outline" style="justify-content: center;">
                    Retour à l'accueil
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
