{% extends 'base.html.twig' %}

{% block title %}Mon Compte Utilisateur{% endblock %}

{% block body %}
<div class="page-header">
    <h1 class="page-title">
        <em>Informations de compte</em>
        Mon Profil Utilisateur
    </h1>
</div>

<div style="max-width: 800px; margin: 0 auto;">
    <div class="card">
        <div class="card-body" style="padding: 3rem;">
            <div style="display: flex; align-items: center; gap: 2rem; margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border);">
                <div style="width: 80px; height: 80px; border-radius: 50%; background: #ec4899; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: 700;">
                    {{ app.user.userIdentifier|first|upper }}
                </div>
                <div>
                    <h2 style="font-family: 'Playfair Display', serif; color: var(--ink); margin-bottom: 0.5rem;">{{ app.user.userIdentifier }}</h2>
                    <span class="badge badge-info">
                        {% if is_granted('ROLE_ADMIN') %}Administrateur Système
                        {% else %}Utilisateur Standard
                        {% endif %}
                    </span>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                <div class="info-group">
                    <label class="info-label">Identifiant / Email</label>
                    <div class="info-value">{{ app.user.userIdentifier }}</div>
                </div>
                <div class="info-group">
                    <label class="info-label">Type d'accès</label>
                    <div class="info-value">
                        {% for role in app.user.roles %}
                            <span class="badge-chip" style="font-size: 0.7rem;">{{ role }}</span>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <div class="alert alert-info" style="margin-top: 3rem;">
                <i class="fas fa-info-circle"></i> 
                Note : Vous êtes connecté avec un compte de gestion globale. Les fonctionnalités de prêt de livres sont réservées aux profils Étudiants et Personnel.
            </div>
        </div>
    </div>
</div>
{% endblock %}
