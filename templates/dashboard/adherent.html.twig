{% extends 'base.html.twig' %}

{% block title %}Mon Espace - Adhérent{% endblock %}

{% block breadcrumb %}
    <li class="sep">/</li>
    <li>Mon espace</li>
    <li class="sep">/</li>
    <li>Mes emprunts</li>
{% endblock %}

{% block body %}
    <div class="page-header">
        <h1 class="page-title">
            {{ adherent.nom }} {{ adherent.prenom }}
            Gestion des Emprunts
        </h1>
    </div>

    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-label">Total Emprunts</div>
            <div class="stat-value">{{ emprunts|length }}</div>
            <div class="stat-delta"><i class="fas fa-history"></i> Historique complet</div>
        </div>
        <div class="stat-card" style="border-top-color: var(--pink-500)">
            <div class="stat-label">Pénalités totales</div>
            {% set total_penalite = 0 %}
            {% for e in emprunts %}
                {% if e.penalite %}
                    {% set total_penalite = total_penalite + e.penalite %}
                {% endif %}
            {% endfor %}
            <div class="auth-sub">Accès réservé aux étudiants et au personnel de l'université</div>
            <div class="stat-value">{{ total_penalite }} €</div>
            <div class="stat-delta" style="color: var(--danger-text)">À régler à la bibliothèque</div>
        </div>
    </div>

    <div class="alert alert-info">
        <strong>Note pour les étudiants :</strong> Pensez à rendre vos ouvrages avant la date limite pour éviter les pénalités de retard. En cas de perte, veuillez contacter le personnel immédiatement.
    </div>

    <div class="card">
        <div class="card-body">
            <h3 style="margin-bottom: 1.5rem; font-family: 'Playfair Display', serif; color: var(--pink-600);">Historique de mes lectures</h3>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Date Emprunt</th>
                        <th>Date Retour</th>
                        <th>État</th>
                        <th>Pénalité</th>
                        <th>Gestion des Bibliothécaires</th>
                    </tr>
                </thead>
                <tbody>
                {% for emprunt in emprunts %}
                    <tr>
                        <td>{{ emprunt.dateEmprunt ? emprunt.dateEmprunt|date('d/m/Y') : '' }}</td>
                        <td>{{ emprunt.dateRetour ? emprunt.dateRetour|date('d/m/Y') : '-' }}</td>
                        <td>
                            <span class="badge badge-{{ emprunt.etat|replace({'_': '-'}) }}">
                                {{ emprunt.etat|capitalize|replace({'_': ' '}) }}
                            </span>
                        </td>
                        <td>{{ emprunt.penalite ? emprunt.penalite ~ ' €' : '0 €' }}</td>
                        <td>{{ emprunt.bibliothecaire.nom }} {{ emprunt.bibliothecaire.prenom }}</td>
                    </tr>
                {% else %}
                    <tr class="empty-row">
                        <td colspan="5">
                            <i class="fas fa-book-reader"></i>
                            Vous n'avez pas encore d'emprunts.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
