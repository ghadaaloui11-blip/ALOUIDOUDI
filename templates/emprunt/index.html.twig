{% extends 'base.html.twig' %}

{% block title %}Gestion des Emprunts{% endblock %}

{% block breadcrumb %}
    <li class="sep">/</li>
    <li>Administration</li>
    <li class="sep">/</li>
    <li>Emprunts</li>
{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('app_emprunt_new') }}" class="btn btn-primary btn-sm">
        <i class="fas fa-plus"></i> Nouvel Emprunt
    </a>
{% endblock %}

{% block body %}
    <div class="page-header">
        <h1 class="page-title">
            <em>Registres de prêt</em>
            Gestion des Emprunts
        </h1>
    </div>

    <div class="card">
        <div class="card-body">
            <table class="data-table">
                <thead>
                    <tr>
                        <th class="id-cell">ID</th>
                        <th>Date Emprunt</th>
                        <th>Date Retour</th>
                        <th>Pénalité</th>
                        <th>État</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for emprunt in emprunts %}
                    <tr>
                        <td class="id-cell">#{{ emprunt.id }}</td>
                        <td>{{ emprunt.dateEmprunt ? emprunt.dateEmprunt|date('d/m/Y') : '' }}</td>
                        <td>{{ emprunt.dateRetour ? emprunt.dateRetour|date('d/m/Y') : '-' }}</td>
                        <td>
                            {% if emprunt.penalite %}
                                <span style="color: var(--danger-text); font-weight: 700;">{{ emprunt.penalite }} €</span>
                            {% else %}
                                <span style="color: var(--success-text);">0 €</span>
                            {% endif %}
                        </td>
                        <td>
                            <span class="badge badge-{{ emprunt.etat|replace({'_': '-'}) }}">
                                {{ emprunt.etat|capitalize|replace({'_': ' '}) }}
                            </span>
                        </td>
                        <td>
                            <div class="action-group" style="justify-content: flex-end;">
                                <a href="{{ path('app_emprunt_show', {'id': emprunt.id}) }}" class="action-link view">
                                    <i class="fas fa-eye"></i> Voir
                                </a>
                                <a href="{{ path('app_emprunt_edit', {'id': emprunt.id}) }}" class="action-link edit">
                                    <i class="fas fa-edit"></i> Modifier
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr class="empty-row">
                        <td colspan="6">
                            <i class="fas fa-book-reader"></i>
                            Aucun emprunt enregistré.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
