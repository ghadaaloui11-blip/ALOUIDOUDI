{% extends 'base.html.twig' %}

{% block title %}Gestion des Bibliothécaires{% endblock %}

{% block breadcrumb %}
    <li class="sep">/</li>
    <li>Administration</li>
    <li class="sep">/</li>
    <li>Bibliothécaires</li>
{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('app_bibliothecaire_new') }}" class="btn btn-primary btn-sm">
        <i class="fas fa-plus"></i> Nouveau Bibliothécaire
    </a>
{% endblock %}

{% block body %}
    <div class="page-header">
        <h1 class="page-title">
            <em>Équipe de gestion</em>
            Gestion des Bibliothécaires 🌸
        </h1>
    </div>

    <div class="card">
        <div class="card-body">
            <table class="data-table">
                <thead>
                    <tr>
                        <th class="id-cell">ID</th>
                        <th>Matricule</th>
                        <th>Nom</th>
                        <th>Prénom</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for bibliothecaire in bibliothecaires %}
                    <tr>
                        <td class="id-cell">#{{ bibliothecaire.id }}</td>
                        <td><span class="badge-chip">{{ bibliothecaire.matricule }}</span></td>
                        <td style="font-weight: 600;">{{ bibliothecaire.nom|upper }}</td>
                        <td>{{ bibliothecaire.prenom }}</td>
                        <td>
                            <div class="action-group" style="justify-content: flex-end;">
                                <a href="{{ path('app_bibliothecaire_show', {'id': bibliothecaire.id}) }}" class="action-link view">
                                    <i class="fas fa-eye"></i> Voir
                                </a>
                                <a href="{{ path('app_bibliothecaire_edit', {'id': bibliothecaire.id}) }}" class="action-link edit">
                                    <i class="fas fa-edit"></i> Modifier
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr class="empty-row">
                        <td colspan="5">
                            <i class="fas fa-user-tie"></i>
                            Aucun bibliothécaire enregistré.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
