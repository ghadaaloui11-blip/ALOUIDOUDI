{% extends 'base.html.twig' %}

{% block title %}Gestion des Adhérents{% endblock %}

{% block breadcrumb %}
    <li class="sep">/</li>
    <li>Administration</li>
    <li class="sep">/</li>
    <li>Adhérents</li>
{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('app_adherent_new') }}" class="btn btn-primary btn-sm">
        <i class="fas fa-plus"></i> Nouvel Adhérent
    </a>
{% endblock %}

{% block body %}
    <div class="page-header">
        <h1 class="page-title">
            <em>Liste des membres</em>
            Gestion des Adhérents
        </h1>
    </div>

    <div class="card">
        <div class="card-body">
            <table class="data-table">
                <thead>
                    <tr>
                        <th class="id-cell">ID</th>
                        <th>CIN</th>
                        <th>Nom</th>
                        <th>Prénom</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for adherent in adherents %}
                    <tr>
                        <td class="id-cell">#{{ adherent.id }}</td>
                        <td><span class="badge-chip">{{ adherent.cin }}</span></td>
                        <td style="font-weight: 600;">{{ adherent.nom|upper }}</td>
                        <td>{{ adherent.prenom }}</td>
                        <td>
                            <div class="action-group" style="justify-content: flex-end;">
                                <a href="{{ path('app_adherent_show', {'id': adherent.id}) }}" class="action-link view">
                                    <i class="fas fa-eye"></i> Voir
                                </a>
                                <a href="{{ path('app_adherent_edit', {'id': adherent.id}) }}" class="action-link edit">
                                    <i class="fas fa-edit"></i> Modifier
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr class="empty-row">
                        <td colspan="5">
                            <i class="fas fa-users-slash"></i>
                            Aucun adhérent enregistré.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
